@inject ToastService Toast
@implements IDisposable

@if (_visible && _message is not null)
{
    <div class="toast-host">
        <div class="toast toast-@KindClass(_message.Kind)">
            <div class="toast-icon">@KindIcon(_message.Kind)</div>
            <div class="toast-body">@_message.Text</div>
            <button class="toast-close" @onclick="HideNow">&times;</button>
        </div>
    </div>
}

<style>
    .toast-host {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 1000;
        pointer-events: none;
    }
    .toast {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-left-width: 4px;
        border-radius: var(--radius-sm);
        padding: 12px 14px;
        display: flex;
        align-items: flex-start;
        gap: 10px;
        min-width: 280px;
        max-width: 420px;
        box-shadow: 0 6px 24px rgba(0,0,0,0.3);
        pointer-events: auto;
        animation: toast-slide 0.2s ease-out;
    }
    .toast-success { border-left-color: var(--success); }
    .toast-error { border-left-color: var(--danger); }
    .toast-info { border-left-color: #3b82f6; }
    .toast-warning { border-left-color: var(--warning); }

    .toast-icon { font-size: 1.1rem; }
    .toast-body { flex: 1; font-size: 0.85rem; color: var(--text-primary); line-height: 1.4; }
    .toast-close {
        background: transparent;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        font-size: 1.2rem;
        padding: 0 4px;
        line-height: 1;
    }
    .toast-close:hover { color: var(--text-primary); }

    @@keyframes toast-slide {
        from { transform: translateX(20px); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }
</style>

@code {
    private ToastMessage? _message;
    private bool _visible;
    private CancellationTokenSource? _hideCts;

    protected override void OnInitialized()
    {
        Toast.OnShow += HandleShow;
    }

    private async void HandleShow(ToastMessage msg)
    {
        _hideCts?.Cancel();
        _hideCts = new CancellationTokenSource();
        var token = _hideCts.Token;

        _message = msg;
        _visible = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(msg.DurationMs, token);
            _visible = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException) { /* superseded */ }
    }

    private void HideNow()
    {
        _hideCts?.Cancel();
        _visible = false;
    }

    public void Dispose()
    {
        Toast.OnShow -= HandleShow;
        _hideCts?.Cancel();
        _hideCts?.Dispose();
    }
}
