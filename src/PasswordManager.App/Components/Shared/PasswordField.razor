@* Custom password input with a persistent Show/Hide toggle. *@

<div class="input-group password-field">
    <input type="@(_visible ? "text" : "password")"
           class="form-control"
           value="@Value"
           @oninput="OnChanged"
           @onkeydown="OnKey"
           placeholder="@Placeholder"
           autocomplete="off" />
    <button class="btn btn-secondary btn-sm" type="button"
            @onclick="Toggle"
            title="@(_visible ? "Hide" : "Show")">
        @(_visible ? "Hide" : "Show")
    </button>
</div>

@code {
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = string.Empty;
    [Parameter] public EventCallback<KeyboardEventArgs> OnEnter { get; set; }

    private bool _visible;

    private void Toggle() => _visible = !_visible;

    private async Task OnChanged(ChangeEventArgs e)
    {
        Value = e.Value?.ToString() ?? string.Empty;
        await ValueChanged.InvokeAsync(Value);
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await OnEnter.InvokeAsync(e);
    }
}
