@page "/generator"
@inject IPasswordGenerator Generator
@inject GeneratorPreferences Prefs
@inject ToastService Toast

<div class="page-header">
    <h1>Password generator</h1>
    <p>Generate strong passwords. These preferences are used whenever you press "Generate" in the vault.</p>
</div>

<div class="card" style="padding:24px;">
    <div class="generated-box">@_password</div>

    @if (!string.IsNullOrEmpty(_password))
    {
        <div class="strength-bar">
            @{ var s = Generator.CalculateStrength(_password); }
            <div class="strength-fill strength-@s" style="width:@(s * 12.5)%"></div>
        </div>
        <small style="color:var(--text-muted);">Strength score: @s / 8</small>
    }

    <div class="actions">
        <button class="btn btn-primary" @onclick="Regenerate">Generate new</button>
        <button class="btn btn-secondary" @onclick="CopyPassword">Copy</button>
    </div>

    <div class="grid-2">
        <div class="form-group">
            <label>Length: <strong>@Prefs.Options.Length</strong></label>
            <input type="range" min="8" max="64" @bind="Prefs.Options.Length" @bind:event="oninput"
                   @bind:after="OnPrefsChanged" style="width:100%; accent-color:var(--accent);" />
        </div>

        <div>
            <div class="form-check">
                <input type="checkbox" @bind="Prefs.Options.IncludeUppercase" @bind:after="OnPrefsChanged" id="upper" />
                <label for="upper">Uppercase (A-Z)</label>
            </div>
            <div class="form-check">
                <input type="checkbox" @bind="Prefs.Options.IncludeLowercase" @bind:after="OnPrefsChanged" id="lower" />
                <label for="lower">Lowercase (a-z)</label>
            </div>
            <div class="form-check">
                <input type="checkbox" @bind="Prefs.Options.IncludeDigits" @bind:after="OnPrefsChanged" id="digits" />
                <label for="digits">Digits (0-9)</label>
            </div>
            <div class="form-check">
                <input type="checkbox" @bind="Prefs.Options.IncludeSpecial" @bind:after="OnPrefsChanged" id="special" />
                <label for="special">Special characters</label>
            </div>
        </div>
    </div>

    <div class="form-group">
        <label>
            Exclude characters
            <InfoTooltip>
                <strong>Why exclude characters?</strong>
                <p style="margin:6px 0 0 0;">
                    Useful to skip lookalikes like <code>0/O</code>, <code>1/l/I</code> on fonts that
                    confuse them, or characters that some websites reject.
                </p>
            </InfoTooltip>
        </label>
        <input type="text" class="form-control" @bind="Prefs.Options.ExcludeChars"
               @bind:event="oninput" @bind:after="OnPrefsChanged"
               placeholder="0Ol1I" />
    </div>
</div>

<style>
    .generated-box {
        font-family: 'Consolas', 'Courier New', monospace;
        font-size: 1.3rem;
        word-break: break-all;
        padding: 16px;
        background: var(--bg-input);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        color: var(--accent);
        text-align: center;
        min-height: 56px;
    }
    .actions {
        display: flex;
        gap: 10px;
        justify-content: center;
        margin: 18px 0 22px;
    }
</style>

@code {
    private string _password = string.Empty;

    protected override void OnInitialized()
    {
        Prefs.OnChanged += Regenerate;
        Regenerate();
    }

    private void OnPrefsChanged()
    {
        Prefs.Notify();
        Regenerate();
    }

    private void Regenerate()
    {
        try { _password = Generator.Generate(Prefs.Options); }
        catch (Exception ex) { _password = string.Empty; Toast.Error($"Generator: {ex.Message}"); }
        StateHasChanged();
    }

    private async Task CopyPassword()
    {
        if (string.IsNullOrEmpty(_password)) return;
        await Clipboard.Default.SetTextAsync(_password);
        Toast.Success("Password copied to clipboard.");
    }

    public void Dispose() => Prefs.OnChanged -= Regenerate;
}
