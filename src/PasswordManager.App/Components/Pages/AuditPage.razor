@page "/audit"
@inject AppState AppState
@inject NavigationManager Nav
@inject IVaultAuditor Auditor

@if (AppState.Service is null) { Nav.NavigateTo("/"); return; }

<div class="page-header">
    <h1>Vault Audit</h1>
    <p>Analyze your vault for security issues</p>
</div>

@if (_report is null)
{
    <div style="text-align:center; padding:40px;">
        <button class="btn btn-primary" @onclick="RunAudit" disabled="@_loading">
            @(_loading ? "Analyzing..." : "Run Audit")
        </button>
    </div>
}
else
{
    <div class="grid-4" style="margin-bottom:24px;">
        <div class="stat-card">
            <div class="stat-value">@_report.TotalPasswords</div>
            <div class="stat-label">Total Passwords</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="color:var(--danger);">@_report.WeakCount</div>
            <div class="stat-label">Weak</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="color:#f97316;">@_report.ReusedCount</div>
            <div class="stat-label">Reused</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="color:var(--warning);">@_report.ExpiredCount</div>
            <div class="stat-label">Expired</div>
        </div>
    </div>

    @if (_report.Issues.Count == 0)
    {
        <div class="alert alert-success">No security issues found. Your vault is in great shape!</div>
    }
    else
    {
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Entry</th>
                        <th>Issue</th>
                        <th>Severity</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var issue in _report.Issues.OrderByDescending(i => i.Severity))
                    {
                        <tr>
                            <td>@issue.EntryLabel</td>
                            <td>@issue.Type</td>
                            <td><span class="badge badge-@issue.Severity.ToString().ToLower()">@issue.Severity</span></td>
                            <td style="color:var(--text-secondary);">@issue.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div style="margin-top:16px;">
        <button class="btn btn-secondary" @onclick="RunAudit">Re-run Audit</button>
    </div>
}

@code {
    private AuditReport? _report;
    private bool _loading;

    private async Task RunAudit()
    {
        _loading = true;
        StateHasChanged();

        _report = await AppState.Service!.AuditVaultAsync(Auditor);

        _loading = false;
    }
}
